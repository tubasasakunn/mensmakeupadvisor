default_platform(:ios)

PROJECT = "mensmakeupadvisor.xcodeproj"
SCHEME  = "mensmakeupadvisor"
BUNDLE_ID = "com.tubasasakun.mensmakeupadvisor"

platform :ios do
  # ──────────────────────────────────────────────
  # CI: ビルド確認（署名なし）— PR・push で実行
  # ──────────────────────────────────────────────
  desc "Simulator build without code signing"
  lane :build_check do
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME,
      destination: "generic/platform=iOS Simulator",
      xcargs: "CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' SKIP_INSTALL=YES -quiet",
    )
  end

  # ──────────────────────────────────────────────
  # 初回のみ: Match リポジトリと証明書を作成
  # ローカルで `bundle exec fastlane setup_match` を実行する
  # ──────────────────────────────────────────────
  desc "Initialize Match certs repo (run once locally)"
  lane :setup_match do
    match(type: "appstore", readonly: false, force_for_new_devices: true)
    match(type: "development", readonly: false, force_for_new_devices: true)
  end

  # ──────────────────────────────────────────────
  # TestFlight へアップロード — タグ push / 手動で実行
  # ──────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_basic_authorization: match_git_auth,
    )

    increment_build_number(
      build_number: next_build_number(api_key: api_key),
      xcodeproj: PROJECT,
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      xcargs: "-quiet",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV.fetch("RELEASE_NOTES", commit_changelog),
    )

    clean_build_artifacts
  end

  # ──────────────────────────────────────────────
  # App Store 審査提出 — 手動実行のみ
  # ──────────────────────────────────────────────
  desc "Submit to App Store review"
  lane :release do
    setup_ci

    api_key = asc_api_key

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_basic_authorization: match_git_auth,
    )

    increment_build_number(
      build_number: next_build_number(api_key: api_key),
      xcodeproj: PROJECT,
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
    )

    clean_build_artifacts
  end

  # ──────────────────────────────────────────────
  # Private helpers
  # ──────────────────────────────────────────────
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )
  end

  private_lane :match_git_auth do
    # base64("github_username:github_pat") — GitHub Secret: MATCH_GIT_BASIC_AUTH
    ENV.fetch("MATCH_GIT_BASIC_AUTH", "")
  end

  private_lane :next_build_number do |options|
    latest_testflight_build_number(
      api_key: options[:api_key],
      app_identifier: BUNDLE_ID,
      initial_build_number: 0,
    ) + 1
  end

  private_lane :commit_changelog do
    sh("git log --oneline -5 --no-decorate 2>/dev/null || echo 'Update'").strip
  end
end
