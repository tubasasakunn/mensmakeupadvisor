    "jp_serif_url": "https://raw.githubusercontent.com/google/fonts/main/ofl/notoserifjp/NotoSerifJP%5Bwght%5D.ttf",
    "latin_sans_ttf": "",
    "latin_mono_ttf": ""
  }
