{
  "_comment": "swift-base 共通設定。scripts/*.py・fastlane/Fastfile・post/_brand.py がここを読む。アプリ＝Tone（メンズメイク診断）。",

  "app": {
    "name": "Tone",
    "reading": "トーン",
    "bundle_id": "com.tubasasakun.mensmakeupadvisor",
    "scheme": "mensmakeupadvisor",
    "xcodeproj": "mensmakeupadvisor.xcodeproj",
    "url_scheme": "tone",
    "deployment_target": "26.0"
  },

  "appstore": {
    "primary_locale": "ja",
    "contact_email": "bassa.application@gmail.com",
    "github_repo": "tubasasakunn/mensmakeupadvisor",
    "primary_category": "LIFESTYLE",
    "secondary_category": "PHOTO_AND_VIDEO",
    "marketing_domain": "https://tone.basaapp.com"
  },

  "brand": {
    "_comment": "ストア画像・SNS 画像の共通カラートークン。アプリの DesignTokens（ダーク×ウォームラグジュアリー）と揃える。RGB 0-255。",
    "bg": [22, 18, 17],
    "ink": [240, 233, 224],
    "sub_ink": [156, 146, 137],
    "card": [38, 32, 30],
    "wordmark": "Tone",
    "accents": {
      "morning": [214, 150, 110],
      "forenoon": [214, 176, 96],
      "afternoon": [196, 122, 92],
      "evening": [202, 70, 54],
      "night": [180, 142, 96],
      "midnight": [126, 138, 158]
    },
    "icon_color": [202, 70, 54]
  },

  "fonts": {
    "_comment": "見出し用日本語フォントは OFL の Noto を実行時に /tmp へ取得する。英字ロゴ用フォントはアプリ同梱の ttf 相対パス（無ければ Noto Sans にフォールバック）。",
